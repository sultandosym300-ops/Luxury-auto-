{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "NODE_ENV=production pnpm --filter @workspace/blackline run build",
  "outputDirectory": "artifacts/blackline/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://workspaceapi-server-production-0d86.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
